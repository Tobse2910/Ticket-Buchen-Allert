PORT=3001

# ── Telegram Bot ────────────────────────────────────────────────────────────
# Bot erstellen via @BotFather auf Telegram → /newbot
TELEGRAM_TOKEN=DEIN_BOT_TOKEN_HIER
# Deine Chat-ID → @userinfobot auf Telegram schreiben
TELEGRAM_CHAT_ID=DEINE_CHAT_ID_HIER

# ── Ticketmaster Discovery API ──────────────────────────────────────────────
# Kostenlosen API-Key holen: https://developer.ticketmaster.com/
TM_API_KEY=DEIN_TM_API_KEY_HIER

# ── Optional: N8N Webhook ───────────────────────────────────────────────────
N8N_WEBHOOK_URL=

# ── Tunnel (optional) ───────────────────────────────────────────────────────
# Auf true setzen um den Cloudflare Tunnel zu deaktivieren (lokal testen)
DISABLE_TUNNEL=false
